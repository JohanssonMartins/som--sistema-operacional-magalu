// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  role     String
  unidade  String
  password String?
  photo    String?
  active   Boolean @default(true)
}

model ChecklistItem {
  id                       String   @id @default(uuid())
  code                     String
  pilar                    String
  bloco                    String
  trilha                   String
  item                     String
  descricao                String
  score                    String?
  exigeEvidencia           Boolean  @default(false)
  ativo                    Boolean  @default(true)
  order                    Int
  assigneeId               String?
  assigneeId2              String?
  assigneeId3              String?
  completed                Boolean? @default(false)
  aderente                 Boolean?
  completedAt              String?
  nossaAcao                String?
  periodoAcao              String?
  justificativaResponsavel String?
  prioridade               String?
  prazo                    String?
  unidade                  String?
  auditoriaTexto           String?
  auditoriaRealizada       Boolean? @default(false)
  auditoriaAderente        Boolean?
  auditoriaCompletedAt     String?
  
  // Relations
  evidencias               Evidencia[]
}

model Evidencia {
  id              String        @id @default(uuid())
  name            String
  url             String
  category        String
  checklistItemId String
  checklistItem   ChecklistItem @relation(fields: [checklistItemId], references: [id])
}

model BaseChecklistItem {
  id             String  @id @default(uuid())
  code           String
  pilar          String
  bloco          String
  trilha         String
  item           String
  descricao      String
  criterios      String?
  exigeEvidencia Boolean @default(false)
  ativo          Boolean @default(true)
  order          Int
  nossaAcao      String?

  // Audit fields
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedBy      String?
  updatedAt      DateTime @updatedAt
}

// Modelos para a Autoauditoria Mensal
model Autoauditoria {
  id          String   @id @default(uuid())
  unidade     String
  mesAno      String   // Ex: "Fevereiro-2026"
  tipo        String   @default("AUTO") // "AUTO" ou "EXTERNA"
  status      String   @default("Pendente de Auditoria") // Pendente de Auditoria, Auditado, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  items       AutoauditoriaItem[]
  
  @@unique([unidade, mesAno, tipo])
}

model AutoauditoriaItem {
  id              String        @id @default(uuid())
  autoauditoriaId String
  autoauditoria   Autoauditoria @relation(fields: [autoauditoriaId], references: [id], onDelete: Cascade)
  
  baseItemId      String
  score           String?
  nossaAcao       String?
  
  evidencias      EvidenciaAutoauditoria[]

  @@unique([autoauditoriaId, baseItemId])
}

model EvidenciaAutoauditoria {
  id                  String            @id @default(uuid())
  name                String
  url                 String
  autoauditoriaItemId String
  autoauditoriaItem   AutoauditoriaItem @relation(fields: [autoauditoriaItemId], references: [id], onDelete: Cascade)
}
