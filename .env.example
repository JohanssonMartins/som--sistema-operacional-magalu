# 📋 Exemplo de Configuração de Variáveis de Ambiente (.env)

# O Sistema Operacional Magalog (S.O.M) requer estas variáveis para funcionar corretamente no Backend.
# Copie este arquivo para .env e preencha os valores.

# --- 💾 BANCO DE DADOS (Supabase) ---
# Use a string de conexão direta ou via Pooler (se estiver no Prisma).
DATABASE_URL="postgresql://postgres:senha@aws-0-regiao.pooler.supabase.com:6543/postgres?pgbouncer=true"

# --- 🧠 INTELIGÊNCIA ARTIFICIAL (Google Gemini) ---
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIzaSyA..."

# --- 📂 ARMAZENAMENTO (Google Drive) ---
# Conteúdo completo do arquivo JSON da conta de serviço (Service Account).
# Em ambientes como Railway/Render, cole o JSON completo minificado nesta variável.
GOOGLE_CREDENTIALS='{"type": "service_account", "project_id": "...", "private_key_id": "...", "private_key": "...", ...}'

# --- 🌐 SERVIDOR (Opcional) ---
# Porta onde o servidor Express irá rodar (Padrão: 3333).
PORT=3333

# --- 🔗 FRONTEND (Apenas para desenvolvimento local) ---
# URL da API para o Frontend (React) saber onde se conectar.
VITE_API_URL="http://localhost:3333"
